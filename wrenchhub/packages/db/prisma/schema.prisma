generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   // "car_owner" or "mechanic"
  isAdmin   Boolean  @default(false) @map("is_admin")
  location  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicles        Vehicle[]
  mechanicProfile MechanicProfile?
  jobs            Job[]
  bids            Bid[]
  sentMessages    Message[]      @relation("sender")
  conversations   ConversationParticipant[]
  reviewsGiven    Review[]       @relation("reviewer")
  passwordResets  PasswordReset[]

  @@map("users")
}

model Vehicle {
  id      String  @id @default(cuid())
  ownerId String  @map("owner_id")
  vin     String?
  year    Int
  make    String
  model   String
  trim    String?
  mileage Int

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  jobs  Job[]

  @@map("vehicles")
}

model MechanicProfile {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  businessName      String   @map("business_name")
  location          String
  latitude          Float?
  longitude         Float?
  serviceAreaRadius Int      @default(15) @map("service_area_radius")
  serviceType       String   @default("shop") @map("service_type")
  services          String[]
  certifications    String[]
  yearsExperience   Int      @default(0) @map("years_experience")
  photos            String[]
  profilePhoto      String?  @map("profile_photo")
  coverPhoto        String?  @map("cover_photo")
  verified          Boolean  @default(false)
  about             String   @default("")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bids    Bid[]
  reviews Review[]

  @@map("mechanic_profiles")
}

model Job {
  id                    String   @id @default(cuid())
  ownerId               String   @map("owner_id")
  vehicleId             String   @map("vehicle_id")
  title                 String
  description           String
  category              String   // maintenance, repair, diagnostics, body_work, other
  subCategory           String?  @map("sub_category")
  photos                String[]
  serviceTypePreference String   @default("no_preference") @map("service_type_preference") // mobile, shop, no_preference
  urgency               String   @default("flexible") // flexible, within_a_week, asap
  location              String
  status                String   @default("active") // draft, active, bidding, accepted, completed, closed
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  vehicle       Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  bids          Bid[]
  conversations Conversation[]
  reviews       Review[]

  @@map("jobs")
}

model Bid {
  id                    String   @id @default(cuid())
  jobId                 String   @map("job_id")
  mechanicId            String   @map("mechanic_id")
  mechanicProfileId     String   @map("mechanic_profile_id")
  totalPrice            Float    @map("total_price")
  partsBreakdown        String   @map("parts_breakdown") // JSON string of itemized parts
  laborHours            Float    @map("labor_hours")
  laborRate             Float    @map("labor_rate")
  fees                  Float    @default(0)
  estimatedCompletionTime String @map("estimated_completion_time")
  notes                 String   @default("")
  availability          String   @default("")
  status                String   @default("pending") // pending, accepted, rejected, withdrawn
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  mechanic        User             @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  mechanicProfile MechanicProfile  @relation(fields: [mechanicProfileId], references: [id], onDelete: Cascade)

  @@unique([jobId, mechanicId])
  @@map("bids")
}

model Conversation {
  id        String   @id @default(cuid())
  jobId     String?  @map("job_id")
  createdAt DateTime @default(now()) @map("created_at")

  job          Job?                      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  lastReadAt     DateTime @default(now()) @map("last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  text           String
  photos         String[]
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Review {
  id                String   @id @default(cuid())
  jobId             String   @map("job_id")
  mechanicProfileId String   @map("mechanic_profile_id")
  reviewerId        String   @map("reviewer_id")
  rating            Int      // 1-5
  text              String
  mechanicResponse  String?  @map("mechanic_response")
  createdAt         DateTime @default(now()) @map("created_at")

  job             Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  mechanicProfile MechanicProfile @relation(fields: [mechanicProfileId], references: [id], onDelete: Cascade)
  reviewer        User            @relation("reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([jobId, reviewerId])
  @@map("reviews")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}
