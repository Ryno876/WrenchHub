generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   // "car_owner" or "mechanic"
  location  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicles        Vehicle[]
  mechanicProfile MechanicProfile?
  jobs            Job[]
  bids            Bid[]

  @@map("users")
}

model Vehicle {
  id      String  @id @default(cuid())
  ownerId String  @map("owner_id")
  vin     String?
  year    Int
  make    String
  model   String
  trim    String?
  mileage Int

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  jobs  Job[]

  @@map("vehicles")
}

model MechanicProfile {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  businessName      String   @map("business_name")
  location          String
  latitude          Float?
  longitude         Float?
  serviceAreaRadius Int      @default(15) @map("service_area_radius")
  serviceType       String   @default("shop") @map("service_type")
  services          String[]
  certifications    String[]
  yearsExperience   Int      @default(0) @map("years_experience")
  photos            String[]
  profilePhoto      String?  @map("profile_photo")
  coverPhoto        String?  @map("cover_photo")
  verified          Boolean  @default(false)
  about             String   @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bids Bid[]

  @@map("mechanic_profiles")
}

model Job {
  id                    String   @id @default(cuid())
  ownerId               String   @map("owner_id")
  vehicleId             String   @map("vehicle_id")
  title                 String
  description           String
  category              String   // maintenance, repair, diagnostics, body_work, other
  subCategory           String?  @map("sub_category")
  photos                String[]
  serviceTypePreference String   @default("no_preference") @map("service_type_preference") // mobile, shop, no_preference
  urgency               String   @default("flexible") // flexible, within_a_week, asap
  location              String
  status                String   @default("active") // draft, active, bidding, accepted, completed, closed
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  owner   User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  vehicle Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  bids    Bid[]

  @@map("jobs")
}

model Bid {
  id                    String   @id @default(cuid())
  jobId                 String   @map("job_id")
  mechanicId            String   @map("mechanic_id")
  mechanicProfileId     String   @map("mechanic_profile_id")
  totalPrice            Float    @map("total_price")
  partsBreakdown        String   @map("parts_breakdown") // JSON string of itemized parts
  laborHours            Float    @map("labor_hours")
  laborRate             Float    @map("labor_rate")
  fees                  Float    @default(0)
  estimatedCompletionTime String @map("estimated_completion_time")
  notes                 String   @default("")
  availability          String   @default("")
  status                String   @default("pending") // pending, accepted, rejected, withdrawn
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  mechanic        User             @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  mechanicProfile MechanicProfile  @relation(fields: [mechanicProfileId], references: [id], onDelete: Cascade)

  @@unique([jobId, mechanicId])
  @@map("bids")
}
